# ==================================================
# DATABASE
# ==================================================
DATABASE_URL="postgresql://user:password@localhost:5432/ai_recruiter?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/ai_recruiter?schema=public"

# ==================================================
# CLERK AUTH
# ==================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxx"
CLERK_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ==================================================
# GROQ (resume parsing + AI evaluation)
# ==================================================
GROQ_API_KEY="gsk_xxxxxxxxxxxx"
GROQ_MODEL="llama-3.3-70b-versatile"

# ==================================================
# MURF FALCON VOICE API
# ==================================================
MURF_API_KEY="murf_xxxxxxxxxxxx"
MURF_API_BASE_URL="https://api.murf.ai/v1"
MURF_VOICE_ID="en-US-natalie"

# ==================================================
# UPLOADTHING
# ==================================================
UPLOADTHING_TOKEN="ut_xxxxxxxxxxxx"

# ==================================================
# RESEND
# ==================================================
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="AI Recruiter <recruiter@yourdomain.com>"

# ==================================================
# WEBTRACKY ANALYTICS
# ==================================================
NEXT_PUBLIC_WEBTRACKY_SITE_ID="wt_xxxxxxxxxxxx"

# ==================================================
# RATE LIMITING (Upstash Redis)
# ==================================================
